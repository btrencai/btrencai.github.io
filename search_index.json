n     scanf(\"%d%d\",&a,&b);\n     printf(\"%d\",a+b);\n}\nH\n#include  \nint main( )\n{ \n   int x,y;\n   int r;\n   scanf(\"%d%d\",&x,&y);\n   r=x-y;\n   printf(\"%d-%d=%d\\n\",x,y,r);\n}\n"},"3010-di-1-zhou-3011-jian-dan-c-cheng-xu/ke-hou-lian-xi.html":{"url":"3010-di-1-zhou-3011-jian-dan-c-cheng-xu/ke-hou-lian-xi.html","title":"课后练习","keywords":"","body":"A\n#include\nint main(void)\n{\n   printf(\"*****\\n\");\n   printf(\" ***\\n\");\n   printf(\"  *\\n\");\n   printf(\" ***\\n\");\n   printf(\"*****\\n\");\n}\nB\n#include\nint main(void)\n{\n   printf(\"    *\\n\");\n   printf(\"   ***\\n\");\n   printf(\"  *****\\n\");\n   printf(\" *******\\n\");\n   printf(\"*********\\n\");\n}\nC\n#include \nint main()\n{\n   int x,y,temp;                              //声明三个整型变量                              \n\n   printf(\"请输入x,y的值:\");                  //提示输入数据\n\n     scanf(\"%d,%d\",&x,&y);                       //输入2个整数的值，中间用逗号分隔 \n\n  printf(\"交换前:x = %d , y = %d\\n\", x,y );   //输出原来的x和y的值\n\n  temp=x ;                                   //先把x的值藏一下                                \n  x =   y;                                     // 把y的值放到x处 \n  y =   temp;                                   //把x的原值放到y处，那么，x的原值藏在哪里呢？\n\n   printf(\"交换后:x = %d , y = %d\\n\", x,y );   //输出交换后的x和y的值  \n}\nD\n#include \nint main()\n{\n   int a,m,f;\n   scanf(\"%d\",&a);\nf=a+28;\nm=f-2;\nprintf(\"%d %d\",f,m);\n\n}\nE\n#include \nint main()\n{\n   int a,m;\n   scanf(\"%d%d\",&a,&m);\nprintf(\"%d\",a-m);\n\n}\nF\n#include \nint main()\n{\n   int a,m;\n   scanf(\"%d%d\",&a,&m);\nprintf(\"%d %d %d\\n\",a+m,a-m,a*m);\nprintf(\"%d\\n\",a+m);\nprintf(\"%d\\n\",a-m);\nprintf(\"%d\\n\",a*m);\n}\nG\n#include \nint main()\n{\n   int a,b;\n   scanf(\"%d %d\",&a,&b);\n   printf(\"%d %d\",a/b,a%b);\n}\nH\n#include \nint main()\n{\n   int a,b,sum;\n   scanf(\"%d %d\",&a,&b);\n   sum=a*b*(b+1)/2;\n   printf(\"%d\",sum);\n}\n"},"3010-di-2-zhou-3011-shu-ju-lei-xing-3001-yun-suan-fu-he-biao-da-shi.html":{"url